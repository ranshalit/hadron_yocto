From: Copilot <copilot@github.com>
Date: Tue, 29 Apr 2026 00:00:00 +0000
Subject: [PATCH] fix: use PEP 621 license table format for setuptools compat

Yocto native setuptools validates pyproject.toml against PEP 621 schema,
which requires license = {text = "..."} or {file = "..."}.
linuxpy 0.24.0 uses the newer PEP 639 bare-string form which fails
validation. Convert to the PEP 621 dict form.

--- a/pyproject.toml
+++ b/pyproject.toml
@@ -6,8 +6,7 @@
 [project]
 name = "linuxpy"
 description = "Human friendly interface to linux subsystems using python"
-license = "GPL-3.0-or-later"
-license-files = ["LICENSE"]
+license = {text = "GPL-3.0-or-later"}
 authors = [
     { name = "Jose Tiago Macara Coutinho", email = "coutinhotiago@gmail.com" }
 ]
